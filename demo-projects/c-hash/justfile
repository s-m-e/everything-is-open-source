# FNV-1a hash demo (C99) — build, run, disassemble, and stage for analysis.
#
# Goal of this project: produce the *same* tiny program with different
# compilers, optimisation levels, architectures, and with/without symbols, so
# the resulting machine code can be disassembled and compared. See README.md
# for the tools required.
#
# The reverse-engineering exercise itself lives in blind/AGENTS.md and operates
# ONLY on the artefacts staged into blind/ — never on src/. Run `just stage`
# to (re)populate blind/, then point an analysis agent at the blind/ folder.

build_dir   := "build"
blind_dir   := "blind"
src         := "src/fnv1a.c"
cflags      := "-std=c99 -Wall -Wextra"
# qemu-user needs the aarch64 sysroot to locate the dynamic loader and libc.
arm_sysroot := "/usr/aarch64-linux-gnu"

# List available recipes.
default:
    @just --list

# ---------------------------------------------------------------------------
# Native x86_64 builds
# ---------------------------------------------------------------------------

# Build ONE native variant. cc in {gcc, clang}; opt in {0, 2}.
#   just build gcc 2
build cc opt:
    mkdir -p {{build_dir}}
    {{cc}} {{cflags}} -O{{opt}} -o {{build_dir}}/fnv1a-{{cc}}-o{{opt}} {{src}}
    @echo "built {{build_dir}}/fnv1a-{{cc}}-o{{opt}}"

# Build the full native matrix: {gcc,clang} x {-O0,-O2}.
build-all:
    just build gcc 0
    just build gcc 2
    just build clang 0
    just build clang 2

# ---------------------------------------------------------------------------
# Cross builds for ARMv8 / AArch64 (run later under qemu)
# ---------------------------------------------------------------------------

# Build ONE aarch64 variant with the GNU cross compiler. opt in {0, 2}.
build-arm-gcc opt:
    mkdir -p {{build_dir}}
    aarch64-linux-gnu-gcc {{cflags}} -O{{opt}} -o {{build_dir}}/fnv1a-arm-gcc-o{{opt}} {{src}}
    @echo "built {{build_dir}}/fnv1a-arm-gcc-o{{opt}}"

# Build ONE aarch64 variant with clang. opt in {0, 2}.
# clang generates the AArch64 code; the GNU cross driver does the linking
# (lld + the multilib sysroot mis-resolve libc.so's GROUP script, so we don't
# link with clang directly). The body code is still clang's.
build-arm-clang opt:
    mkdir -p {{build_dir}}
    clang --target=aarch64-linux-gnu {{cflags}} -O{{opt}} -c {{src}} -o {{build_dir}}/_arm-clang-o{{opt}}.o
    aarch64-linux-gnu-gcc -O{{opt}} {{build_dir}}/_arm-clang-o{{opt}}.o -o {{build_dir}}/fnv1a-arm-clang-o{{opt}}
    rm -f {{build_dir}}/_arm-clang-o{{opt}}.o
    @echo "built {{build_dir}}/fnv1a-arm-clang-o{{opt}}"

# Build the aarch64 matrix (gcc -O0/-O2, clang -O2).
build-arm-all:
    just build-arm-gcc 0
    just build-arm-gcc 2
    just build-arm-clang 2

# Build everything native + arm.
all: build-all build-arm-all

# ---------------------------------------------------------------------------
# Third dimension: strip symbols (mimics a real "shipping" binary)
# ---------------------------------------------------------------------------

# Strip a native binary -> <bin>-stripped (removes the symbol table, so
# fnv1a_hash / main no longer have names).
strip bin:
    cp {{build_dir}}/{{bin}} {{build_dir}}/{{bin}}-stripped
    strip -s {{build_dir}}/{{bin}}-stripped
    @echo "stripped -> {{build_dir}}/{{bin}}-stripped"

# Strip an aarch64 binary (needs the cross strip).
strip-arm bin:
    cp {{build_dir}}/{{bin}} {{build_dir}}/{{bin}}-stripped
    aarch64-linux-gnu-strip -s {{build_dir}}/{{bin}}-stripped
    @echo "stripped -> {{build_dir}}/{{bin}}-stripped"

# Strip the realistic "shipping" variants (-O2, both compilers, both arches).
strip-all:
    just strip fnv1a-gcc-o2
    just strip fnv1a-clang-o2
    just strip-arm fnv1a-arm-gcc-o2
    just strip-arm fnv1a-arm-clang-o2

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

# Run a native binary. Extra args are passed to the program.
#   just run fnv1a-gcc-o2 "hello world"
run bin *args:
    ./{{build_dir}}/{{bin}} {{args}}

# Run an aarch64 binary under qemu user mode.
#   just run-arm fnv1a-arm-gcc-o2 "hello world"
run-arm bin *args:
    qemu-aarch64 -L {{arm_sysroot}} ./{{build_dir}}/{{bin}} {{args}}

# Known-answer check: every native variant prints the same hash for the
# default input. Build with `just build-all` first.
check:
    #!/usr/bin/env bash
    set -euo pipefail
    for b in {{build_dir}}/fnv1a-gcc-* {{build_dir}}/fnv1a-clang-*; do
        case "$b" in *.s) continue;; esac
        [ -x "$b" ] && printf "%-30s %s\n" "$(basename "$b")" "$("$b")"
    done

# ---------------------------------------------------------------------------
# Disassembly
# ---------------------------------------------------------------------------

# Disassemble a native x86_64 binary to both AT&T and Intel syntax .s files.
#   just disasm fnv1a-gcc-o2
disasm bin:
    objdump -d -M att   {{build_dir}}/{{bin}} > {{build_dir}}/{{bin}}.att.s
    objdump -d -M intel {{build_dir}}/{{bin}} > {{build_dir}}/{{bin}}.intel.s
    @echo "wrote {{build_dir}}/{{bin}}.att.s and {{build_dir}}/{{bin}}.intel.s"

# Disassemble only the hash function from a native binary (concise view).
# Note: at -O2 the static fnv1a_hash is usually INLINED into main and has no
# symbol of its own, so this falls back to disassembling main.
disasm-fn bin:
    #!/usr/bin/env bash
    set -uo pipefail
    if nm {{build_dir}}/{{bin}} 2>/dev/null | grep -qi fnv1a_hash; then
        objdump -d -M intel --disassemble=fnv1a_hash {{build_dir}}/{{bin}}
    else
        echo "No standalone fnv1a_hash symbol — likely inlined; disassembling main:"
        objdump -d -M intel --disassemble=main {{build_dir}}/{{bin}}
    fi

# Disassemble an aarch64 binary (cross objdump understands the ARM ELF).
disasm-arm bin:
    aarch64-linux-gnu-objdump -d {{build_dir}}/{{bin}} > {{build_dir}}/{{bin}}.arm.s
    @echo "wrote {{build_dir}}/{{bin}}.arm.s"

# Quick triage of a binary: file type, symbols, strings.
inspect bin:
    @echo "== file =="     && file {{build_dir}}/{{bin}}
    @echo "== symbols ==" && nm {{build_dir}}/{{bin}} 2>/dev/null | grep -i fnv || echo "(no fnv symbol — stripped or inlined)"
    @echo "== strings ==" && strings {{build_dir}}/{{bin}} | grep -iE "quick|gcc|clang|GCC:" || true

# ---------------------------------------------------------------------------
# Stage artefacts into blind/ for the analysis agent (NO source is copied)
# ---------------------------------------------------------------------------

# Rebuild the whole matrix, strip the shipping variants, and publish ONE opaque
# folder per binary into blind/. Each folder gets the binary as `demo`, its
# disassembly as `demo.asm`, and a copy of the single-binary AGENTS.md. The
# variant name appears only in the operator manifest, never inside a folder, so
# an agent given one folder cannot tell it apart from any other or know that
# siblings exist. Files an operator/agent added (recon, solution) are kept.
stage: all strip-all
    #!/usr/bin/env bash
    set -euo pipefail
    manifest={{blind_dir}}/_manifest.txt
    : > "$manifest"
    n=0
    for b in {{build_dir}}/fnv1a-*; do
        name=$(basename "$b")
        case "$name" in *.s) continue;; esac
        n=$((n+1))
        dir={{blind_dir}}/$(printf 'case-%02d' "$n")
        mkdir -p "$dir"
        cp "$b" "$dir/demo"
        if [[ "$name" == *arm* ]]; then
            aarch64-linux-gnu-objdump -d "$dir/demo" > "$dir/demo.asm"
        else
            objdump -d -M intel "$dir/demo" > "$dir/demo.asm"
        fi
        cp {{blind_dir}}/AGENTS.md "$dir/AGENTS.md"
        printf '%-10s %s\n' "$(basename "$dir")" "$name" >> "$manifest"
    done
    echo "staged $n binaries into {{blind_dir}}/ — one opaque folder each (demo, demo.asm, AGENTS.md)"
    echo "operator map: $manifest"
    echo "give an analysis agent ONE folder only, e.g. {{blind_dir}}/case-01"

# ---------------------------------------------------------------------------
# Grade a reconstruction against the original (the answer key)
# ---------------------------------------------------------------------------

# Drop the reference source next to a reconstruction and grade it: a
# behavioural comparison (compile both, run on several inputs) plus a textual
# diff. Run this only AFTER the analyst has committed its work. recon = path to
# the reconstructed source (.c built with gcc, .rs with rustc); the reference is
# placed alongside it as solution-<name>.
#   just grade blind/case-01/recon.c
grade recon:
    #!/usr/bin/env bash
    set -euo pipefail
    orig=$(dirname "{{recon}}")/solution-$(basename {{src}})
    cp {{src}} "$orig"
    compile() { case "$1" in
        *.rs) rustc -O -o "$2" "$1";;
        *.c)  gcc -O2 -o "$2" "$1";;
        *) echo "unknown source type: $1" >&2; return 1;; esac; }
    echo "== behavioural comparison =="
    compile "$orig"     /tmp/grade-orig
    compile "{{recon}}" /tmp/grade-recon
    pass=1
    for s in "" "a" "the quick brown fox" "hello world" "1234567890"; do
        o=$(/tmp/grade-orig "$s"); r=$(/tmp/grade-recon "$s")
        label=${s:-"(no-arg default)"}
        if [ "$o" = "$r" ]; then printf "  OK    %s\n" "$label"
        else printf "  FAIL  %s  orig=%s recon=%s\n" "$label" "$o" "$r"; pass=0; fi
    done
    [ $pass -eq 1 ] && echo "BEHAVIOUR: identical" || echo "BEHAVIOUR: MISMATCH"
    echo
    echo "== textual diff (original <-> reconstruction) =="
    if diff -u "$orig" "{{recon}}"; then echo "(byte-for-byte identical)"; fi || true

# Remove build artefacts and the staged blind/ case folders (binaries,
# disassembly, AGENTS.md copies, and any recon/solution dropped in them). Keeps
# the master blind/AGENTS.md template. `stage` itself does NOT call this, so
# re-staging preserves anything you added to a case folder.
clean:
    rm -rf {{build_dir}}
    rm -rf {{blind_dir}}/case-* {{blind_dir}}/_manifest.txt
